# ─── Core (필수) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 둘 중 한쪽이라도 설정하면 동작 — 코드가 둘 다 참조함. 통일 권장.
SUPABASE_SERVICE_ROLE=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

CRON_SECRET=openssl-rand-base64-32    # Vercel Cron 인증
NEXT_PUBLIC_SITE_URL=https://nutunion.co.kr  # health-watch / 절대 URL 생성에 사용

# ─── AI (Vercel AI Gateway) ───────────────────────────
# Vercel Deploy: OIDC 자동 — 추가 env 불필요.
# 로컬: `vercel env pull` 또는:
AI_GATEWAY_API_KEY=                   # Gateway 콘솔에서 발급
# (레거시 — Gateway 전환 권장)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=                       # 또는 GOOGLE_AI_API_KEY / GOOGLE_GENERATIVE_AI_API_KEY (셋 중 하나)
USD_TO_KRW=1380                       # AI 비용 환산 (옵션)

# ─── STT (OpenAI Whisper) ─────────────────────────────
# /api/ai/transcribe — 회의 녹음·음성 메모 텍스트 변환. 미설정시 503.
OPENAI_API_KEY=sk-...

# ─── 키 볼트 (사용자별 AI 키 암호화) ──────────────────
# 우선순위: NU_KEY_VAULT_SECRET > SUPABASE_JWT_SECRET > NEXTAUTH_SECRET > 기본값
# 운영에서는 NU_KEY_VAULT_SECRET 명시 권장 — 다른 비밀과 회전 주기 분리.
NU_KEY_VAULT_SECRET=                  # 32-byte base64
SUPABASE_JWT_SECRET=                  # Supabase Dashboard → Settings → API
# NEXTAUTH_SECRET=                    # 레거시 fallback (NextAuth 미사용 시 비워도 됨)

# ─── 결제 (Toss / PortOne) ────────────────────────────
TOSS_SECRET_KEY=test_sk_...           # test_ → live_
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_...

PORTONE_API_KEY=
PORTONE_API_SECRET=
NEXT_PUBLIC_PORTONE_STORE_ID=imp...

# ─── 이메일 (Resend) ──────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM="nutunion <noreply@nutunion.co.kr>"

# ─── 카카오 알림톡 (NCP SENS) ─────────────────────────
NCP_SENS_SERVICE_ID=ncp:sms:kr:...
NCP_SENS_ACCESS_KEY=
NCP_SENS_SECRET_KEY=
NCP_SENS_KAKAO_CHANNEL_ID=@nutunion
NCP_SENS_SENDER_PHONE=01012345678

# ─── 세금계산서 (Popbill) ─────────────────────────────
POPBILL_LINK_ID=
POPBILL_SECRET_KEY=
POPBILL_CORP_NUM=1234567890
POPBILL_USER_ID=ADMIN
POPBILL_MODE=TEST                     # TEST | PRODUCTION

# ─── 전자서명 (모두싸인) ──────────────────────────────
MODUSIGN_API_KEY=
MODUSIGN_USER_EMAIL=
MODUSIGN_TEMPLATE_ID=                 # 선택

# ─── OAuth 외부 연동 ──────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_STATE_SECRET=                   # HMAC 서명용 32-byte base64

# Google OAuth (Calendar/Drive 연동)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://nutunion.co.kr/api/google/oauth/callback

# Google Drive 공유 폴더/Shared Drive (자료실 사본 저장)
GOOGLE_DRIVE_SHARED_DRIVE_ID=         # 팀 드라이브 ID (선택)
GOOGLE_DRIVE_SHARED_FOLDER_ID=        # 공유 루트 폴더 ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=          # 개인 OAuth 모드 루트 폴더 ID
NUTUNION_DRIVE_OWNER_USER_ID=         # 운영 Drive 소유자 user_id (admin backfill 용)
NEXT_PUBLIC_GOOGLE_DRIVE_PARENT_ID=   # 클라이언트 사이드 직접 업로드용 부모 폴더

# ─── Cloudflare R2 (자료실/아바타/이미지 호스팅) ─────
# 미설정시 자료실 업로드는 Supabase Storage 폴백.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nutunion-resources
R2_PUBLIC_URL=https://cdn.nutunion.co.kr  # 또는 https://<bucket>.<account>.r2.dev

# ─── Web Push (VAPID) ─────────────────────────────────
# 생성: npm i -g web-push && web-push generate-vapid-keys
# 미설정시 웹 푸시 비활성 — Expo(모바일)만 동작. dispatch 가 log.warn 으로 가시화.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nutunion.co.kr   # web-push-client 기본값과 일치

# ─── Feature Flags (Vercel Flags) ─────────────────────
FLAGS=                                # Vercel 대시보드에서 플래그 생성 시 자동 주입
FLAGS_SECRET=                         # 32-byte base64 (openssl rand -base64 32)

# ─── 분석 (PostHog) — 선택 ────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ─── 운영 모니터링 알림 (선택) ────────────────────────
ALERT_WEBHOOK_URL=                    # health-watch cron 실패 알림 (Slack/Discord webhook)
ALERT_MENTION=                        # 알림 prefix (예: <!channel>)

# ─── Vercel API (선택) ────────────────────────────────
# Flags 관리 / deploy hook 등 일부 admin 라우트만 사용
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# ─── Mobile (apps/mobile/.env.local 별도) ─────────────
# 루트가 아닌 apps/mobile 에 별도 파일. 동기화 안내:
#   EXPO_PUBLIC_API_BASE=https://nutunion.co.kr
#   EXPO_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL 와 동일
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY 와 동일
# 자세한 내용: apps/mobile/DEPLOY.md
