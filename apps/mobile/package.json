{
  "name": "nutunion-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:dev": "eas build --profile development --platform all --non-interactive",
    "build:preview": "eas build --profile preview --platform all --non-interactive",
    "build:prod": "eas build --profile production --platform all --non-interactive",
    "submit:preview:ios": "eas submit --profile preview --platform ios --latest",
    "submit:preview:android": "eas submit --profile preview --platform android --latest",
    "submit:prod": "eas submit --profile production --platform all --latest",
    "update:preview": "eas update --branch preview --message",
    "update:prod": "eas update --branch production --message",
    "release:preview": "eas build --profile preview --platform all --auto-submit --non-interactive"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.0",
    "expo-linking": "~6.3.0",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "expo-sqlite": "~14.0.0",
    "@react-native-community/netinfo": "11.3.1",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.0",
    "react-native-screens": "3.31.0",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.0",
    "typescript": "^5.3.0"
  }
}
